{
  "name": "@mantle-ai/source",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.8.0",
  "scripts": {
    "build": "npm run -ws --if-present build",
    "test": "npm run -ws --if-present test",
    "lint": "npm run -ws --if-present lint",
    "validate": "node scripts/validate-all.sh",
    "docs:dev": "npm --prefix docs run dev",
    "docs:build": "npm --prefix docs run build",
    "docs:start": "npm --prefix docs run start"
  },
  "workspaces": [
    "mcp-server",
    "packages/plugins/*"
  ],
  "devDependencies": {
    "nx": "22.0.2",
    "typescript": "5.9.3"
  }
}
